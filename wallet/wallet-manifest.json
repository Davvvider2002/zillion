{
  "name": "Zillion Wallet",
  "short_name": "Zillion",
  "description": "Offline-first digital cash for everyone",
  "start_url": "/wallet/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0D1F1A",
  "theme_color": "#0D1F1A",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "file_handlers": [
    {
      "action": "/wallet/",
      "accept": { "application/octet-stream": [".zil"] }
    }
  ],
  "share_target": {
    "action": "/wallet/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "zil_file", "accept": ["application/octet-stream", ".zil"] }]
    }
  },
  "screenshots": [
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "form_factor": "narrow" }
  ]
}
