# ─── Zillion Mint Keys (generated via: npm run mint:keygen) ──────────────────
# NEVER commit real values. Store in Netlify environment variables.
MINT_PRIVATE_KEY_HEX=your-ed25519-private-key-hex-here
MINT_PUBLIC_KEY_HEX=your-ed25519-public-key-hex-here
MINT_ID=ZILLION-MINT-01

# ─── App Config ──────────────────────────────────────────────────────────────
ZILLION_ENV=development
# Options: development | staging | production

MAX_WALLET_BALANCE_KOBO=1000000
# 1,000,000 kobo = ₦10,000 pilot cap

MAX_COIN_VALUE_KOBO=100000
# 100,000 kobo = ₦1,000 max single coin (pilot)

AGENT_VERIFY_THRESHOLD_KOBO=500000
# 500,000 kobo = ₦5,000 — above this, agent must verify online

COIN_EXPIRY_DAYS=90
# Pilot expiry: 90 days

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-secret-min-32-chars-here

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_VALIDATE_PER_MIN=60
RATE_LIMIT_SYNC_PER_MIN=10
